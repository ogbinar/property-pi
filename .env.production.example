# ===========================================
# Property-Pi Production Environment
# ===========================================
# Copy this file to .env.production and fill in your values
# ===========================================

# --- Frontend (Next.js) ---

# PocketBase URL for browser-based SDK calls (production)
# Must be publicly accessible (e.g., https://pb.yourdomain.com)
NEXT_PUBLIC_POCKETBASE_URL=https://your-pocketbase-url.com

# --- Backend (FastAPI) ---

# PocketBase admin API URL (production)
# Can be internal network URL if backend and PocketBase are on same network
BACKEND_POCKETBASE_URL=http://pb:8090

# PocketBase admin authentication token for server-to-server calls
# Generate via: ./pocketbase settings api
BACKEND_POCKETBASE_ADMIN_TOKEN=your-admin-token-here

# FastAPI server port (usually set by container)
BACKEND_FASTAPI_PORT=8000

# Secret key for session/token generation (MUST be unique and secure)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
BACKEND_SECRET_KEY=your-secure-random-key-here
