# Frontend - FastAPI backend URL (browser-accessible)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side API URL (for Dokploy: set to http://property-pi.apps.ogbinar.com)
# This is used by Next.js server components to reach the backend
API_URL=

# Backend - Database URL
DATABASE_URL=sqlite:///../property_pi.db

# Backend - FastAPI port
BACKEND_FASTAPI_PORT=8002
