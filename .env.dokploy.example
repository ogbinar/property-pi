# Dokploy Environment Variables
# Copy this to .env and fill in your values

# ===========================================
# FRONTEND (Next.js)
# ===========================================
# Public URL where your frontend will be accessible
# For Dokploy: https://your-domain.com or http://server-ip:3000
NEXT_PUBLIC_POCKETBASE_URL=https://your-domain.com:8090
NEXT_PUBLIC_API_URL=https://your-domain.com:8000

# ===========================================
# BACKEND (FastAPI)
# ===========================================
# Internal PocketBase URL (from backend's perspective)
BACKEND_POCKETBASE_URL=http://pocketbase:8090

# Admin token for backend to access PocketBase
# Generate this in PocketBase Admin UI → Settings → API
BACKEND_POCKETBASE_ADMIN_TOKEN=your-admin-token-here

# Secret key for JWT/session management
BACKEND_SECRET_KEY=your-super-secret-key-change-this

# CORS allowed origins (comma-separated)
# Format: https://your-domain.com,http://localhost:3000
CORS_ORIGINS=https://your-domain.com,http://localhost:3000

# ===========================================
# DOCKPLOY SPECIFIC
# ===========================================
# If using Dokploy's reverse proxy, set your domain
# Example: property-pi.your-domain.com
# DOCKPLOY_DOMAIN=property-pi.your-domain.com
