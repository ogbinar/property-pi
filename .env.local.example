# ===========================================
# Property-Pi Development Environment
# ===========================================
# Copy this file to .env.local and fill in your values
# ===========================================

# --- Frontend (Next.js) ---

# PocketBase URL for browser-based SDK calls (local development)
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8090

# --- Backend (FastAPI) ---

# PocketBase admin API URL (local development)
BACKEND_POCKETBASE_URL=http://localhost:8090

# PocketBase admin authentication token for server-to-server calls
BACKEND_POCKETBASE_ADMIN_TOKEN=

# FastAPI server port
BACKEND_FASTAPI_PORT=8000

# Secret key for session/token generation (generate with: python -c "import secrets; print(secrets.token_hex(32))")
BACKEND_SECRET_KEY=change-this-in-production
