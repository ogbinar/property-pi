# ===========================================
# Property-Pi Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
#
# Usage: cp .env.example .env
# ===========================================

# --- Frontend (Next.js) ---

# PocketBase URL for browser-based SDK calls
# Must be publicly accessible in production (e.g., https://pb.yourdomain.com)
# Default: http://localhost:8090
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8090

# --- Backend (FastAPI) ---

# PocketBase admin API URL (internal server-to-server communication)
# Can be internal network URL in production (not exposed to browser)
# Default: http://localhost:8090
BACKEND_POCKETBASE_URL=http://localhost:8090

# PocketBase admin authentication token for server-to-server calls
# Generate via: ./pocketbase settings api
# Leave empty for local development (uses default admin account)
BACKEND_POCKETBASE_ADMIN_TOKEN=

# FastAPI server port
# Default: 8000
BACKEND_FASTAPI_PORT=8000
