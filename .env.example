# ===========================================
# Property-Pi Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
#
# Usage: cp .env.example .env
# ===========================================

# --- Backend (Python FastAPI) ---

# SQLite database path for backend
# Also accepts: DATABASE_URL (alias)
db_url=sqlite:////data/property_pi.db

# JWT secret key (generate with: openssl rand -base64 32)
# Also accepts: SECRET_KEY (alias)
jwt_secret=change-me-in-production

# JWT token expiration in minutes
# Also accepts: ACCESS_TOKEN_EXPIRE_MINUTES (alias)
access_token_expire_minutes=120

# Comma-separated allowed CORS origins
# Also accepts: ALLOWED_ORIGINS (alias)
allowed_origins=http://localhost:3000

# --- Frontend (Next.js) ---

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000
